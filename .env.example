# OpenMobility OS — environment configuration
# Copy this file to `.env` and adjust the values.

# --- Django ---
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
# Comma-separated list of hostnames/IPs this server answers to. The default
# below is for LOCAL use only — when you deploy to a real server and browse to
# it by domain or IP, you MUST add that host here, or Django rejects every
# request with a bare "400 Bad Request" (DisallowedHost). Example:
# ALLOWED_HOSTS=localhost,127.0.0.1,myserver.example.com
ALLOWED_HOSTS=localhost,127.0.0.1
# Required for HTTPS deployments behind a reverse proxy (comma-separated):
# CSRF_TRUSTED_ORIGINS=https://myserver.example.com
CSRF_TRUSTED_ORIGINS=

# --- Database ---
POSTGRES_DB=openmobility
POSTGRES_USER=openmobility
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgis://openmobility:changeme@db:5432/openmobility

# --- Admin token (protects all write actions) ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=change-me-to-a-random-admin-token

# --- Deployment mode ---
# public-demo  : landing shows all workspaces (good for open public demos)
# single-city  : landing redirects to DEFAULT_WORKSPACE_SLUG
# multi-city   : landing shows all workspaces, admin wizard hidden from nav
DEPLOYMENT_MODE=public-demo
DEFAULT_WORKSPACE_SLUG=

# --- Internationalization ---
DEFAULT_LOCALE=de

# --- Map tiles (swap for a self-hosted tile server if desired) ---
MAP_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
MAP_TILE_ATTRIBUTION=© OpenStreetMap contributors
# Dark-mode basemap (used when the UI is switched to dark). Defaults to
# CARTO's free, keyless OSM dark tiles; point it at your own dark style for
# a fully self-hosted setup.
MAP_TILE_URL_DARK=https://basemaps.cartocdn.com/dark_all/{z}/{x}/{y}.png
MAP_TILE_ATTRIBUTION_DARK=© OpenStreetMap contributors, © CARTO
# Optional satellite/aerial basemap, selectable from the map's "Base map"
# switcher. Defaults to Esri's keyless World Imagery; point it at your own
# aerial WMTS/XYZ layer, or leave it blank to hide the satellite option.
MAP_TILE_URL_SATELLITE=https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}
MAP_TILE_ATTRIBUTION_SATELLITE=Imagery © Esri, Maxar, Earthstar Geographics

# --- OpenStreetMap Overpass API ---
OSM_OVERPASS_API=https://overpass-api.de/api/interpreter

# --- OpenStreetMap Nominatim (geocoding for the new-workspace wizard) ---
# Resolves a place name to a bounding box so admins don't type coordinates by
# hand. Point this at your own Nominatim instance for self-contained hosting.
OSM_NOMINATIM_API=https://nominatim.openstreetmap.org/search

# --- Mobilithek DCAT-AP catalog ---
# BMDV occasionally rotates this URL; admins can override per workspace from the
# data hub UI (Browse catalog → Mobilithek → Catalog URL field).
MOBILITHEK_CATALOG_URL=https://mobilithek.info/mdp-api/files/catalogue/DCAT-AP.rdf

# --- Seed data ---
# Set to 0 to skip automatic demo seeding on first boot
AUTO_SEED_DEMO=1
